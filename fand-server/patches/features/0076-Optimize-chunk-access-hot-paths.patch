index 85e921a8282a0ccc27e9d2f662ffd32085cb7f51..27177e357f8ff8e4ef54450c1068b5f944828711 100644
--- a/net/minecraft/network/FriendlyByteBuf.java
+++ b/net/minecraft/network/FriendlyByteBuf.java
@@ -336,17 +336,17 @@ public class FriendlyByteBuf extends ByteBuf {
     }
 
     public FriendlyByteBuf writeLongArray(final long[] longs) {
-        writeLongArray(this, longs);
+        writeLongArrayBulk(this, longs);
         return this;
     }
 
     public static void writeLongArray(final ByteBuf output, final long[] longs) {
         VarInt.write(output, longs.length);
-        writeFixedSizeLongArray(output, longs);
+        writeFixedSizeLongArrayBulk(output, longs);
     }
 
     public FriendlyByteBuf writeFixedSizeLongArray(final long[] longs) {
-        writeFixedSizeLongArray(this, longs);
+        writeFixedSizeLongArrayBulk(this, longs);
         return this;
     }
 
@@ -356,6 +356,39 @@ public class FriendlyByteBuf extends ByteBuf {
         }
     }
 
+    private static void writeLongArrayBulk(final ByteBuf output, final long[] longs) {
+        VarInt.write(output, longs.length);
+        writeFixedSizeLongArrayBulk(output, longs);
+    }
+
+    private static void writeFixedSizeLongArrayBulk(final ByteBuf output, final long[] longs) {
+        if (longs.length == 0) {
+            return;
+        }
+
+        int neededBytes = longs.length * Long.BYTES;
+        if (output.maxWritableBytes() < neededBytes) {
+            writeFixedSizeLongArray(output, longs);
+            return;
+        }
+
+        output.ensureWritable(neededBytes);
+        int writerIndex = output.writerIndex();
+        if (output.hasArray()) {
+            byte[] target = output.array();
+            int offset = output.arrayOffset() + writerIndex;
+            ByteBuffer.wrap(target, offset, neededBytes).order(output.order()).asLongBuffer().put(longs);
+            output.writerIndex(writerIndex + neededBytes);
+        } else if (output.nioBufferCount() > 0) {
+            output.nioBuffer(writerIndex, neededBytes).order(output.order()).asLongBuffer().put(longs);
+            output.writerIndex(writerIndex + neededBytes);
+        } else {
+            ByteBuffer buffer = ByteBuffer.allocate(neededBytes).order(output.order());
+            buffer.asLongBuffer().put(longs);
+            output.writeBytes(buffer);
+        }
+    }
+
     public long[] readLongArray() {
         return readLongArray(this);
     }
